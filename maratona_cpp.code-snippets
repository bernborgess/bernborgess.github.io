    "Dijkstra's Shortest Path Algorithm": {
        "prefix": "dijkstra",
        "body": [
            "const int MAX = 1010;",
            "vector<vector<pair<int,int>>> g(MAX);",
            "vector<int> dist(MAX,INF);",
            "",
            "void dijkstra(int x) {",
            "  priority_queue<pair<int,int>> pq; pq.push({-0,x});",
            "  while(!pq.empty()) {",
            "    int u=pq.top().f,d = -pq.top().s;",
            "    pq.pop();",
            "    if(d>dist[u])  continue;",
            "    dist[u] = d;",
            "    for(pair<int,int> pv : g[u]) {",
            "      int w = d + pv.f;",
            "      if(dist[pv.s] > w ) {",
            "        pq.push({w,pv.s});",
            "      }",
            "    }",
            "  }",
            "}"
        ],
        "description": "Dijkstra's Shortest Path Algorithm"
