        "prefix": "sfexp",
        "body": [
            "// SUM(i=0,i<n){A^i}",
            "ll sfexp(ll A,ll n) {",
            "  if(n==0) return 0LL;",
            "  if(n==1) return 1LL;",
            "  ll r=((A+1)*sfexp(n/2,(A*A)%MOD))%MOD;",
            "  if(n&1) r=(r+fexp(A,n-1))%MOD;",
            "  return r;",
            "}",
