    "SegTree": {
        "prefix": "segtree",
        "body": [
            "typedef ${1:pii} vectype;",
            "vector<vectype> v;",
            "typedef ${2:pii} segtype;",
            "vector<segtype> seg;",
            "",
            "segtype neutral = ${3:{-INF,INF}};",
            "#define base_el(x) ${4:x}",
            "",
            "segtype combine(segtype a,segtype b) {",
            "  return $0mkp(",
            "    (max(a.f,b.f)),",
            "    (min(a.s,b.s))",
            "  );",
            "}",
            "",
            "segtype build(int p,int l,int r) {",
            "  if(l==r) return seg[p]=base_el(v[l]);",
            "  int m=(l+r)/2;",
            "  return seg[p]=combine(",
            "    build(2*p,l,m),",
            "    build(2*p+1,m+1,r)",
            "  );",
            "}",
            "",
            "segtype query(int a,int b,int p,int l,int r) {",
            "  if(b<l||r<a) return neutral;",
            "  if(a<=l&&r<=b) return seg[p];",
            "  int m=(l+r)/2;",
            "  return combine(",
            "    query(a,b,2*p,l,m),",
            "    query(a,b,2*p+1,m+1,r)",
            "  );",
            "}",
            "",
            "segtype update(int i,vectype x,int p,int l,int r) {",
            "  if(i<l||r<i) return seg[p];",
            "  if(l==r) return seg[p]=base_el(x);",
            "  int m=(l+r)/2;",
            "  return seg[p] = combine(",
            "    update(i,x,2*p,l,m),",
            "    update(i,x,2*p+1,m+1,r)",
            "  );",
            "}",
            "",
            "int main() { _",
            "  int n,q;",
            "  cin>>n>>q;",
            "  v=vector<vectype>(n);",
            "  seg=vector<segtype>(4*n);",
            "  for(vectype&i:v)cin>>i.f>>i.s;",
            "  build(1,0,n-1);",
            "  while(q--) {",
            "    char tipo; cin>>tipo;",
            "    if(tipo=='C') { // update",
            "      int i,l,r;  cin>>i>>l>>r;",
            "      update(i-1,mkp(l,r),1,0,n-1);",
            "    } else { // query",
            "      int l,r; cin>>l>>r; l--,r--;",
            "      segtype ans = query(l,r,1,0,n-1);",
            "      cout<<max(ans.s-ans.f+1,0)<<endl;",
            "    }",
            "  }",
            "  return 0;",
            "}"
        ],
